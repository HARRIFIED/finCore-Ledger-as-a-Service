# ── account-service ──────────────────────────────────────────────────────────
DB_URL=jdbc:postgresql://localhost:5432/account_db
DB_USERNAME=finCore
DB_PASSWORD=finCore_secret

# ── iam-service ──────────────────────────────────────────────────────────────
IAM_DB_URL=jdbc:postgresql://localhost:5432/identity_db
GRPC_SERVER_PORT=9082

# JWT keys — leave blank in dev (ephemeral RSA key generated on startup).
# In staging/prod: populate with PKCS#8 PEM strings.
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# ── Shared infrastructure ────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ZIPKIN_BASE_URL=http://localhost:9411
TRACING_SAMPLE_RATE=1.0